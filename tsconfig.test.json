{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist-test",
    "rootDir": "lib"
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules", "lib/**/*.d.ts"]
}
